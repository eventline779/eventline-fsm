# Kopiere diese Datei nach .env und fuelle die Werte ein.
# .env ist gitignored — landet nicht im Repo.

# ============================================================
# Postgres-Connection — Supabase Pooler (Session-Mode)
# ============================================================
# Hol dir die Werte aus Supabase Dashboard:
#   Project Settings → Database → "Connection pooling" Block
#   → "Session mode" Connection-String anschauen
#
# Beispiel-String aus Supabase:
#   postgresql://postgres.uxtotpniwbwyoznwkygd:[YOUR-PASSWORD]@aws-0-eu-central-2.pooler.supabase.com:5432/postgres
#
# Die einzelnen Felder unten ausfuellen.

PG_HOST=aws-0-eu-central-2.pooler.supabase.com
PG_PORT=5432
PG_USER=postgres.uxtotpniwbwyoznwkygd
PG_PASSWORD=
PG_DATABASE=postgres

# ============================================================
# S3-Storage — Supabase Storage S3 Connection
# ============================================================
# Hol dir die Werte aus Supabase Dashboard:
#   Project Settings → Storage → "S3 Connection" Block
#   → falls "Disabled": auf "Enable" klicken
#   → "New access key" → Name z.B. "ugreen-nas-backup" → Generate
#   → Access Key + Secret kopieren (Secret wird NUR EINMAL gezeigt!)
#
# Endpoint-Format: https://<project-ref>.storage.supabase.co/storage/v1/s3
# Region steht direkt darueber im "S3 Connection"-Block.

S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=https://uxtotpniwbwyoznwkygd.storage.supabase.co/storage/v1/s3
S3_REGION=eu-central-2

# ============================================================
# Backup-Verhalten
# ============================================================
# Stunde im 24h-Format wann der Backup laeuft (Europe/Zurich).
# 3 = 03:00 Uhr nachts (Standard, niedrige App-Last).
BACKUP_HOUR=3

# Wie viele Tage werden Backups aufbewahrt? Aelter wird geloescht.
# 90 Tage = ~3 Monate. Bei knappem NAS-Speicher reduzieren.
RETENTION_DAYS=90
